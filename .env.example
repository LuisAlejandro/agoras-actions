# Copy to secrets.env for local functional testing (see test.sh).
# GitHub Action inputs use the same values with kebab-case names in action.yml.

# Required for every run
NETWORK=twitter
ACTION=post

# Post content
STATUS_TEXT=Hello from Agoras
STATUS_LINK=
STATUS_IMAGE_URL_1=
STATUS_IMAGE_URL_2=
STATUS_IMAGE_URL_3=
STATUS_IMAGE_URL_4=

# Feed and scheduling
FEED_URL=
MAX_COUNT=1
POST_LOOKBACK=3600
MAX_POST_AGE=

# Post IDs (like, share, delete)
TWEET_ID=
FACEBOOK_POST_ID=
INSTAGRAM_POST_ID=
LINKEDIN_POST_ID=

# Twitter
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_OAUTH_TOKEN=
TWITTER_OAUTH_SECRET=

# Facebook
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_OBJECT_ID=
FACEBOOK_PROFILE_ID=

# Instagram
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_OBJECT_ID=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=

# Google Sheets (schedule action)
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_NAME=
