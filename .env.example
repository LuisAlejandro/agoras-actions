# Copy to secrets.env for local functional testing (see test.sh).
# GitHub Action inputs use kebab-case names in action.yml; test.sh maps these vars.

# Required for every run (test.sh currently hardcodes network=x, action=post)
NETWORK=x
ACTION=post

# Post content
STATUS_TEXT=Hello from Agoras
STATUS_LINK=
STATUS_IMAGE_URL_1=
STATUS_IMAGE_URL_2=
STATUS_IMAGE_URL_3=
STATUS_IMAGE_URL_4=

# Post IDs (like, share, delete)
TWEET_ID=
FACEBOOK_POST_ID=
INSTAGRAM_POST_ID=
LINKEDIN_POST_ID=

# X (Twitter)
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_OAUTH_TOKEN=
TWITTER_OAUTH_SECRET=

# Facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REFRESH_TOKEN=
FACEBOOK_OBJECT_ID=
FACEBOOK_PROFILE_ID=
FACEBOOK_APP_ID=

# Instagram
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REFRESH_TOKEN=
INSTAGRAM_OBJECT_ID=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_OBJECT_ID=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_SERVER_NAME=
DISCORD_CHANNEL_NAME=

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_USERNAME=
TIKTOK_REFRESH_TOKEN=

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REFRESH_TOKEN=
THREADS_USER_ID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=

# WhatsApp
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_RECIPIENT=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=
WHATSAPP_TEMPLATE_COMPONENTS=

# Google Sheets (schedule action)
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_NAME=

# Docker Compose (optional; defaults match docker-compose.yml)
UID=1000
GID=1000
